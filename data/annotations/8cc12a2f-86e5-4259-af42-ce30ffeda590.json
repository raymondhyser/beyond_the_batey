    {
      "start_time": 474,
      "end_time": 953,
      "annotation": [
        {
          "text": "\"Petronila Guilbe\" Don Rafael Cepeda Atiles",
          "bold": true
        },
        {
          "type": "line-break",
          "children": [
            {
              "text": ""
            }
          ]
        },
        {
          "text": "Chorus ",
          "bold": true
        },
        {
          "type": "line-break",
          "children": [
            {
              "text": ""
            }
          ]
        },
        {
          "text": "Petronila Guilbe, I do not confess"
        },
        {
          "type": "line-break",
          "children": [
            {
              "text": ""
            }
          ]
        },
        {
          "text": "Verses",
          "bold": true
        },
        {
          "type": "line-break",
          "children": [
            {
              "text": ""
            }
          ]
        },
        {
          "text": "Ay, that I did not confess, that I did not confess\nAy, ask the priest, ask the judge\nAy, let the drums that Manuel played sound\nAy, Petronila Guilbe, that I did not confess\nAy, singing sweet bomba, I’m heading to Mayagüez\n\n"
        }
      ],
