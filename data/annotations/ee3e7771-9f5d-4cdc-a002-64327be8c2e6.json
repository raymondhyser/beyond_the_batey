          "children": [
            {
              "text": ""
            }
          ]
        },
        {
          "text": "Mi Salvatore de viva mue"
        },
        {
          "type": "line-break",
          "children": [
            {
              "text": ""
            }
          ]
        },
        {
          "text": "Versos",
          "bold": true
        },
        {
          "type": "line-break",
          "children": [
            {
              "text": ""
            }
          ]
        },
        {
          "text": "Eso dile a Valentin "
        },
        {
          "type": "line-break",
          "children": [
            {
              "text": ""
            }
          ]
        },
        {
          "text": "Lo que le dice Manuel "
        },
        {
          "type": "line-break",
          "children": [
            {
              "text": ""
            }
          ]
        },
        {
          "text": "Que no vaya pa la bomba si no bailaba Paulé"
        },
        {
          "type": "line-break",
          "children": [
            {
              "text": ""
            }
          ]
        },
        {
          "text": "Ay yo vi ayer Urubina "
        },
        {
          "type": "line-break",
          "children": [
            {
              "text": ""
            }
          ]
        },
        {
          "text": "Me dijo que quiere usted "
        },
        {
          "type": "line-break",
          "children": [
            {
              "text": ""
            }
          ]
        },
        {
          "text": "Que le prenda una vela debe prender al revés "
        },
        {
          "type": "line-break",
          "children": [
            {
              "text": ""
            }
          ]
        },
        {
          "text": "Ya los zumban a la vez por el rio de Portugues "
        },
        {
          "type": "line-break",
          "children": [
            {
              "text": ""
            }
          ]
        },
        {
          "text": "Lleva un hechizo en la mano "
        },
        {
          "type": "line-break",
          "children": [
            {
              "text": ""
            }
          ]
        },
        {
          "text": "Pa conquistar a José"
        },
        {
          "type": "line-break",
          "children": [
            {
              "text": ""
            }
          ]
        },
        {
          "text": "Esa, esa Dominé"
        },
        {
          "type": "line-break",
          "children": [
            {
              "text": ""
            }
          ]
        },
        {
          "text": "Esa, esa Shangoté"
        },
        {
          "type": "line-break",
          "children": [
            {
              "text": ""
            }
          ]
        },
        {
          "text": "Esa, esa viva mué"
        },
        {
          "type": "line-break",
          "children": [
            {
              "text": ""
            }
          ]
        },
        {
          "text": "Mi salvatore de Shangoté"
        }
